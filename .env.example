# Copy to .env.local and fill in secrets. .env.local is gitignored.

# ---- Core ----
ENVIRONMENT=dev                      # dev | staging | prod
LOG_LEVEL=INFO

# ---- Postgres ----
# Local docker-compose default. Render sets DATABASE_URL automatically in prod.
DATABASE_URL=postgresql+asyncpg://motion:motion_dev@localhost:5432/motion

# ---- Auth (Clerk) ----
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_JWKS_URL=https://REPLACE-your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://REPLACE-your-instance.clerk.accounts.dev
# Comma-separated list of frontend origins permitted to present tokens.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
# Svix signing secret for webhook endpoint at POST /webhooks/clerk (Phase 3).
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ---- Optional (phase-2) ----
REDIS_URL=                           # leave empty for in-process event bus
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=motion-cv
